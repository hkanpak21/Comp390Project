# Build artifacts
build/
cmake-build-*/
*.o
*.a
*.so
*.so.*
*.dylib

# CUDA caches
.nv_cache/
*.ptx
*.cubin
*.fatbin

# CMake (only generated Makefiles in build dirs; do NOT match hand-written paper/Makefile)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
build/Makefile
install_manifest.txt
CTestTestfile.cmake

# Compiled binaries
bin/
*.out
*.exe

# Archive directories — superseded files kept for provenance only.
# Tracked already-archived content stays committed; new files dropped here
# don't show up in `git status`. Force-add with `git add -f` if you need to.
/docs/archive/
/paper/archive/
/notes/archive/
/experiments/archive/
/scripts/archive/
/scripts/mn5/archive/
/src/benchmarks/archive/
/src/multi_gpu/archive/

# Profiling outputs
*.nsys-rep
*.ncu-rep
*.qdrep
*.sqlite
*.nvvp

# Large data / model weights
*.bin
*.npy
*.npz
*.h5
*.pt
*.ckpt
data/

# Experiment outputs (large logs)
experiments/results/*.log
experiments/results/*.raw

# Paper build artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.toc
paper/main.pdf
paper/fig*.pdf

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
*.swp
*~

# Python
__pycache__/
*.pyc
.venv/
.venv-*/
venv/

# docs/report LaTeX build artifacts (PDF kept since it's the deliverable)
docs/report/*.aux
docs/report/*.log
docs/report/*.out
docs/report/*.fdb_latexmk
docs/report/*.fls
docs/report/*.synctex.gz
docs/report/*.toc

# experiments/results — per-run raw output dirs are large, keep local only
experiments/results/2026-*

# AWS credentials / secrets — NEVER commit these
*.pem
.aws/credentials
.env
*.env
vendor/phantom_old/
